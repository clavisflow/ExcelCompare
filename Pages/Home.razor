@page "/"
@inject ExcelDiffService DiffService
@inject CsvExportService CsvExport
@inject ISnackbar Snackbar
@inject IJSRuntime JsRuntime

<PageTitle>ClavisFlow | エクセルコンペア</PageTitle>

<section class="diagnostics-shell diff-shell">
    <MudStack Spacing="3">
        <div class="workspace-title">
            <div>
                <a class="product-brand" href="https://clavisflow.net/">
                    <span class="brand-mark" aria-hidden="true"><img src="clavisflow-icon.png" alt=""></span>
                    <span>ClavisFlow</span>
                </a>
                <h1>EXCEL差分比較アプリ「エクセルコンペア」</h1>
                <p class="lead-copy">
                    「どこが変わった？」を一瞬で。<br />
                    EXCELファイルどうしのセル値、数式、名前定義、書式、ファイル構成、VBAマクロの差分を見つけます。<br />
                    🔒ファイルはサーバーへ送信されず、すべての解析をブラウザ上で安全に行います。
                </p>
            </div>
        </div>

        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudFileUpload T="IBrowserFile" Files="_sourceFile" Accept=".xlsx,.xlsm" MaxFileSize="@ExcelDiffService.MaxFileSize" FilesChanged="OnSourceFileChanged">
                    <CustomContent Context="picker">
                        <MudPaper Class="upload-zone clickable-upload" Elevation="0" @onclick="@picker.OpenFilePickerAsync" role="button" tabindex="0">
                            <div class="upload-heading">
                                <span class="upload-icon">A</span>
                                <div>
                                    <MudText Typo="Typo.h6">比較元ファイルを選択またはドロップ</MudText>
                                    <MudText Typo="Typo.body2">.xlsx .xlsm 対応。最大 10MB。</MudText>
                                </div>
                            </div>
                            @RenderMetadata(_sourceMetadata, ClearSourceFile)
                        </MudPaper>
                    </CustomContent>
                    <SelectedTemplate></SelectedTemplate>
                </MudFileUpload>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudFileUpload T="IBrowserFile" Files="_targetFile" Accept=".xlsx,.xlsm" MaxFileSize="@ExcelDiffService.MaxFileSize" FilesChanged="OnTargetFileChanged">
                    <CustomContent Context="picker">
                        <MudPaper Class="upload-zone clickable-upload" Elevation="0" @onclick="@picker.OpenFilePickerAsync" role="button" tabindex="0">
                            <div class="upload-heading">
                                <span class="upload-icon">B</span>
                                <div>
                                    <MudText Typo="Typo.h6">比較先ファイルを選択またはドロップ</MudText>
                                    <MudText Typo="Typo.body2">.xlsx .xlsm 対応。最大 10MB。</MudText>
                                </div>
                            </div>
                            @RenderMetadata(_targetMetadata, ClearTargetFile)
                        </MudPaper>
                    </CustomContent>
                    <SelectedTemplate></SelectedTemplate>
                </MudFileUpload>
            </MudItem>
        </MudGrid>

        <MudPaper Class="control-panel" Elevation="0">
            <MudGrid Spacing="2">
                <MudItem xs="12" lg="9">
                    <MudGrid Spacing="1">
                        <MudItem xs="12" sm="6" md="3">
                            <MudCheckBox @bind-Value="_includeData" Color="Color.Primary" Label="データ" />
                            <MudText Typo="Typo.caption">セル値・数式・名前定義</MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudCheckBox @bind-Value="_includeFormatting" Color="Color.Primary" Label="書式" />
                            <MudText Typo="Typo.caption">背景色・文字色・表示形式</MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudCheckBox @bind-Value="_includeStructure" Color="Color.Primary" Label="ファイル構成" />
                            <MudText Typo="Typo.caption">シート・保護・入力規則・非表示</MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudCheckBox @bind-Value="_includeMacros" Color="Color.Primary" Label="マクロ" />
                            <MudText Typo="Typo.caption">.xlsmどうしのみ</MudText>
                        </MudItem>
                    </MudGrid>
                </MudItem>
                <MudItem xs="12" lg="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.PlayArrow" Disabled="@_isRunning" OnClick="StartCompareAsync">
                            比較開始
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Download" Disabled="@(!FilteredRecords.Any())" OnClick="DownloadCsvAsync">
                            CSV
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>

            @if (_isRunning)
            {
                <MudStack Spacing="1" Class="progress-area">
                    <MudProgressLinear Value="@_progressPercent" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">@_progressStatus</MudText>
                </MudStack>
            }
        </MudPaper>

        @if (_result is not null)
        {
            <MudGrid Spacing="2">
                @SummaryCard("合計", _result.Summary.Total, Icons.Material.Filled.Summarize, Color.Primary, -1)
                @SummaryCard("データ", _result.Summary.CellCount + _result.Summary.MetadataCount, Icons.Material.Filled.GridOn, Color.Info, 0)
                @SummaryCard("書式", _result.Summary.FormattingCount, Icons.Material.Filled.FormatColorFill, Color.Success, 1)
                @SummaryCard("ファイル構成", _result.Summary.StructureCount, Icons.Material.Filled.AccountTree, Color.Secondary, 2)
                @SummaryCard("マクロ", _result.Summary.MacroCount, Icons.Material.Filled.Code, Color.Warning, 3)
            </MudGrid>

            <MudPaper Class="result-panel" Elevation="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="_keyword" Label="キーワード検索" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="2">
                        <MudSelect T="string" @bind-Value="_sheetFilter" Label="シート名" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem T="string" Value="@AllFilter">すべて</MudSelectItem>
                            @foreach (var sheet in SheetOptions)
                            {
                                <MudSelectItem T="string" Value="@sheet">@sheet</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="2">
                        <MudSelect T="string" @bind-Value="_kindFilter" Label="差分種別" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem T="string" Value="@AllFilter">すべて</MudSelectItem>
                            <MudSelectItem T="string" Value="@DiffKind.Added.ToString()">追加</MudSelectItem>
                            <MudSelectItem T="string" Value="@DiffKind.Removed.ToString()">削除</MudSelectItem>
                            <MudSelectItem T="string" Value="@DiffKind.Changed.ToString()">変更</MudSelectItem>
                            <MudSelectItem T="string" Value="@DiffKind.Renamed.ToString()">名称変更</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    @if (_activeTab == 3)
                    {
                        <MudItem xs="12" sm="6" md="3">
                            <MudSelect T="string" @bind-Value="_moduleFilter" Label="モジュール" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem T="string" Value="@AllFilter">すべて</MudSelectItem>
                                @foreach (var module in MacroModuleOptions)
                                {
                                    <MudSelectItem T="string" Value="@module">@module</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    }
                    <MudItem xs="12" md="2">
                        <MudText Typo="Typo.body2" Align="Align.Right">表示 @FilteredRecords.Count 件 / 検出 @CurrentTabDetectedCount().ToString("N0") 件</MudText>
                    </MudItem>
                </MudGrid>

                <MudTabs @bind-ActivePanelIndex="_activeTab" Class="diff-tabs" Rounded="false" Elevation="0">
                    <MudTabPanel Text="データ" Icon="@Icons.Material.Filled.GridOn" />
                    <MudTabPanel Text="書式" Icon="@Icons.Material.Filled.FormatColorFill" />
                    <MudTabPanel Text="ファイル構成" Icon="@Icons.Material.Filled.AccountTree" />
                    <MudTabPanel Text="マクロ" Icon="@Icons.Material.Filled.Code" />
                </MudTabs>

                @if (FilteredRecords.Count == 0)
                {
                    <div class="empty-result">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                        <div>
                            <strong>@CurrentEmptyTitle()</strong>
                            <p>@CurrentEmptyMessage()</p>
                        </div>
                    </div>
                }
                else
                {
                    <MudDataGrid T="DiffRecord"
                                 Items="@FilteredRecords"
                                 Dense="true"
                                 Hover="true"
                                 Bordered="false"
                                 Striped="true"
                                 Filterable="false"
                                 SortMode="SortMode.Multiple"
                                 RowsPerPage="50"
                                 Class="diff-grid">
                        <Columns>
                            <HierarchyColumn T="DiffRecord" EnableHeaderToggle="false" ButtonDisabledFunc="@IsModuleBodyRecord" />
                            <TemplateColumn T="DiffRecord" Title="カテゴリ" SortBy="@(row => row.Category)">
                                <CellTemplate>@CategoryLabel(context.Item.Category)</CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn T="DiffRecord" Title="種別" SortBy="@(row => row.Kind)">
                                <CellTemplate>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@KindColor(context.Item.Kind)">
                                        @KindLabel(context.Item.Kind)
                                    </MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn T="DiffRecord" TProperty="string" Property="row => row.SheetName" Title="シート" />
                            <PropertyColumn T="DiffRecord" TProperty="string" Property="row => row.Address" Title="アドレス" />
                            <PropertyColumn T="DiffRecord" TProperty="string" Property="row => row.Item" Title="項目" />
                            <TemplateColumn T="DiffRecord" Title="比較元" SortBy="@(row => row.SourceValue)">
                                <CellTemplate>@RenderValueCell(context.Item, isSource: true)</CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn T="DiffRecord" Title="比較先" SortBy="@(row => row.TargetValue)">
                                <CellTemplate>@RenderValueCell(context.Item, isSource: false)</CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn T="DiffRecord" TProperty="string" Property="row => row.Detail" Title="詳細" />
                        </Columns>
                        <ChildRowContent>
                            @if (!IsModuleBodyRecord(context.Item))
                            {
                                <div class="diff-detail">
                                    <div>
                                        <span>差分詳細</span>
                                        <p>@context.Item.Detail</p>
                                    </div>
                                    <div class="diff-detail-grid">
                                        <div>
                                            <strong>比較元</strong>
                                            @RenderPreviewBlock(context.Item, isSource: true)
                                        </div>
                                        <div>
                                            <strong>比較先</strong>
                                            @RenderPreviewBlock(context.Item, isSource: false)
                                        </div>
                                    </div>
                                </div>
                            }
                        </ChildRowContent>
                        <PagerContent>
                            <MudDataGridPager T="DiffRecord" PageSizeOptions="@(new[] { 50, 100, 250 })" />
                        </PagerContent>
                    </MudDataGrid>
                }
            </MudPaper>
        }
    </MudStack>

    <footer class="site-footer">
        Built with C#, Blazor WebAssembly and Azure Static Web Apps.
    </footer>
</section>

@code {
    private const string AllFilter = "__all__";

    private IBrowserFile? _sourceFile;
    private IBrowserFile? _targetFile;
    private FileMetadata? _sourceMetadata;
    private FileMetadata? _targetMetadata;
    private CompareResult? _result;
    private bool _includeData = true;
    private bool _includeFormatting = true;
    private bool _includeStructure = true;
    private bool _includeMacros = true;
    private bool _isRunning;
    private int _progressPercent;
    private int _activeTab;
    private string _progressStatus = string.Empty;
    private string _sheetFilter = AllFilter;
    private string _kindFilter = AllFilter;
    private string _moduleFilter = AllFilter;
    private string _keyword = string.Empty;

    private List<DiffRecord> FilteredRecords => ApplyFilters(useDisplayRecords: true).ToList();

    private IEnumerable<string> SheetOptions => _result is null
        ? Enumerable.Empty<string>()
        : _result.DisplayRecords
            .Select(record => record.SheetName)
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Order(StringComparer.OrdinalIgnoreCase);

    private IEnumerable<string> MacroModuleOptions => _result is null
        ? Enumerable.Empty<string>()
        : _result.DisplayRecords
            .Where(record => record.Category == DiffCategory.Macro)
            .Select(MacroModuleName)
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Order(StringComparer.OrdinalIgnoreCase);

    private async Task OnSourceFileChanged(IBrowserFile? file)
    {
        _sourceFile = file;
        _sourceMetadata = await TryReadMetadataAsync(file);
    }

    private async Task OnTargetFileChanged(IBrowserFile? file)
    {
        _targetFile = file;
        _targetMetadata = await TryReadMetadataAsync(file);
    }

    private void ClearSourceFile()
    {
        _sourceFile = null;
        _sourceMetadata = null;
        _result = null;
    }

    private void ClearTargetFile()
    {
        _targetFile = null;
        _targetMetadata = null;
        _result = null;
    }

    private void SelectSummaryTab(int tabIndex)
    {
        if (_result is null)
        {
            return;
        }

        _activeTab = tabIndex >= 0 ? tabIndex : FirstNonEmptyTab();
        ResetFilters();
    }

    private int FirstNonEmptyTab()
    {
        if (_result is null)
        {
            return 0;
        }

        if (_result.Summary.CellCount + _result.Summary.MetadataCount > 0)
        {
            return 0;
        }

        if (_result.Summary.FormattingCount > 0)
        {
            return 1;
        }

        if (_result.Summary.StructureCount > 0)
        {
            return 2;
        }

        if (_result.Summary.MacroCount > 0)
        {
            return 3;
        }

        return 0;
    }

    private async Task<FileMetadata?> TryReadMetadataAsync(IBrowserFile? file)
    {
        if (file is null)
        {
            return null;
        }

        try
        {
            return await DiffService.ReadMetadataAsync(file);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch
        {
            Snackbar.Add("ファイルの解析に失敗しました。ファイルが破損しているか、サイズが大きすぎる可能性があります。", Severity.Error);
        }

        return null;
    }

    private async Task StartCompareAsync()
    {
        if (_sourceFile is null)
        {
            Snackbar.Add("比較元ファイルを選択してください。", Severity.Warning);
            return;
        }

        if (_targetFile is null)
        {
            Snackbar.Add("比較先ファイルを選択してください。", Severity.Warning);
            return;
        }

        _isRunning = true;
        _result = null;
        _progressPercent = 0;
        _progressStatus = "Excel読込中...";

        var progress = new Progress<CompareProgress>(value =>
        {
            _progressStatus = value.Status;
            _progressPercent = value.Percent;
            _ = InvokeAsync(StateHasChanged);
        });

        try
        {
            var options = new ComparisonOptions(_includeData, _includeFormatting, _includeStructure, _includeMacros);
            _result = await DiffService.CompareAsync(_sourceFile, _targetFile, options, progress);
            _sheetFilter = AllFilter;
            _kindFilter = AllFilter;
            _moduleFilter = AllFilter;
            _keyword = string.Empty;
            _activeTab = FirstNonEmptyTab();
            Snackbar.Add($"比較が完了しました。差分 {_result.Summary.Total:N0} 件", Severity.Success);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch
        {
            Snackbar.Add("ファイルの解析に失敗しました。ファイルが破損しているか、サイズが大きすぎる可能性があります。", Severity.Error);
        }
        finally
        {
            _isRunning = false;
        }
    }

    private async Task DownloadCsvAsync()
    {
        var records = ApplyFilters(useDisplayRecords: false).ToList();
        if (records.Count == 0)
        {
            Snackbar.Add("出力対象の差分がありません。", Severity.Info);
            return;
        }

        var bytes = CsvExport.BuildDiffCsv(records);
        var fileName = $"excel-diff-{DateTime.Now:yyyyMMdd-HHmmss}.csv";
        await JsRuntime.InvokeVoidAsync("excelCompare.downloadBytes", fileName, "text/csv;charset=utf-8", Convert.ToBase64String(bytes));
    }

    private void ResetFilters()
    {
        _sheetFilter = AllFilter;
        _kindFilter = AllFilter;
        _moduleFilter = AllFilter;
        _keyword = string.Empty;
    }

    private IEnumerable<DiffRecord> ApplyFilters(bool useDisplayRecords)
    {
        if (_result is null)
        {
            return [];
        }

        var category = ActiveCategory();
        var source = useDisplayRecords ? _result.DisplayRecords : _result.Records;
        var query = source.Where(record => category(record.Category));

        if (_sheetFilter != AllFilter)
        {
            query = query.Where(record => record.SheetName.Equals(_sheetFilter, StringComparison.OrdinalIgnoreCase));
        }

        if (_kindFilter != AllFilter && Enum.TryParse<DiffKind>(_kindFilter, out var kind))
        {
            query = query.Where(record => record.Kind == kind);
        }

        if (_activeTab == 3 && _moduleFilter != AllFilter)
        {
            query = query.Where(record => MacroModuleName(record).Equals(_moduleFilter, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(_keyword))
        {
            query = query.Where(ContainsKeyword);
        }

        return query;
    }

    private Func<DiffCategory, bool> ActiveCategory() => _activeTab switch
    {
        0 => category => category is DiffCategory.Cell or DiffCategory.Metadata,
        1 => category => category == DiffCategory.Formatting,
        2 => category => category == DiffCategory.Structure,
        3 => category => category == DiffCategory.Macro,
        _ => category => true
    };

    private string CurrentEmptyTitle()
    {
        if (_result is null)
        {
            return string.Empty;
        }

        if (!CurrentTabWasCompared())
        {
            return $"{CurrentTabLabel()}は比較対象外です";
        }

        return HasActiveFilters() ? "条件に一致する差分はありません" : $"{CurrentTabLabel()}の差分はありません";
    }

    private string CurrentEmptyMessage()
    {
        if (_result is null)
        {
            return string.Empty;
        }

        if (!CurrentTabWasCompared())
        {
            return "上部の比較対象チェックをONにしてから、もう一度比較してください。";
        }

        return HasActiveFilters()
            ? "検索条件、シート名、差分種別、モジュールの絞り込みを変更してください。"
            : "このカテゴリでは比較元と比較先の差分は検出されませんでした。";
    }

    private string CurrentTabLabel() => _activeTab switch
    {
        0 => "データ",
        1 => "書式",
        2 => "ファイル構成",
        3 => "マクロ",
        _ => "結果"
    };

    private bool CurrentTabWasCompared()
    {
        if (_result is null)
        {
            return false;
        }

        return _activeTab switch
        {
            0 => _result.Options.IncludeData,
            1 => _result.Options.IncludeFormatting,
            2 => _result.Options.IncludeStructure,
            3 => _result.Options.IncludeMacros,
            _ => true
        };
    }

    private bool HasActiveFilters() =>
        _sheetFilter != AllFilter ||
        _kindFilter != AllFilter ||
        (_activeTab == 3 && _moduleFilter != AllFilter) ||
        !string.IsNullOrWhiteSpace(_keyword);

    private int CurrentTabDetectedCount()
    {
        if (_result is null)
        {
            return 0;
        }

        return _activeTab switch
        {
            0 => _result.Summary.CellCount + _result.Summary.MetadataCount,
            1 => _result.Summary.FormattingCount,
            2 => _result.Summary.StructureCount,
            3 => _result.Summary.MacroCount,
            _ => _result.Summary.Total
        };
    }

    private bool ContainsKeyword(DiffRecord record)
    {
        return Contains(record.SheetName) ||
            Contains(record.Address) ||
            Contains(record.Item) ||
            Contains(record.SourceValue) ||
            Contains(record.TargetValue) ||
            Contains(record.Detail);
    }

    private bool Contains(string value) =>
        value.Contains(_keyword, StringComparison.OrdinalIgnoreCase);

    private RenderFragment RenderValueCell(DiffRecord record, bool isSource) =>
        @<div class="value-cell">
            @if (record.Category == DiffCategory.Formatting)
            {
                @RenderStylePreview(isSource ? record.SourceValue : record.TargetValue)
            }
            <span>@(isSource ? record.SourceValue : record.TargetValue)</span>
        </div>;

    private RenderFragment RenderPreviewBlock(DiffRecord record, bool isSource)
    {
        var preview = isSource ? record.SourcePreview : record.TargetPreview;
        var value = isSource ? record.SourceValue : record.TargetValue;

        return @<div class="@PreviewBlockClass(record)">
            @if (record.Category == DiffCategory.Formatting)
            {
                @RenderStylePreview(value)
            }
            @if (!string.IsNullOrEmpty(preview))
            {
                <pre>@preview</pre>
            }
            else if (!string.IsNullOrEmpty(value))
            {
                <pre>@value</pre>
            }
            else
            {
                <em>なし</em>
            }
        </div>;
    }

    private RenderFragment RenderStylePreview(string styleSignature) =>
        @<div class="style-preview">
            @{
                var style = ParseStyleSignature(styleSignature);
                var bgColor = ToCssColor(style.Background);
                var fgColor = ToCssColor(style.Foreground);
            }
            <span class="swatch @(bgColor is null ? "swatch-empty" : string.Empty)" style="background:@(bgColor ?? "transparent")"></span>
            <span class="swatch @(fgColor is null ? "swatch-empty" : string.Empty)" style="background:@(fgColor ?? "transparent")"></span>
            <small>@style.NumberFormat</small>
        </div>;

    private static string PreviewBlockClass(DiffRecord record) =>
        record.Category == DiffCategory.Macro ? "preview-block macro-preview" : "preview-block";

    private static bool IsModuleBodyRecord(DiffRecord record) =>
        record.Category == DiffCategory.Macro && record.Item.EndsWith(" モジュール本体", StringComparison.Ordinal);

    private RenderFragment RenderMetadata(FileMetadata? metadata, Action clearFile) => builder =>
    {
        if (metadata is null)
        {
            builder.OpenComponent<MudText>(0);
            builder.AddAttribute(1, "Typo", Typo.body2);
            builder.AddAttribute(2, "Class", "metadata-empty");
            builder.AddAttribute(3, "ChildContent", (RenderFragment)(b => b.AddContent(4, "未選択")));
            builder.CloseComponent();
            return;
        }

        builder.OpenElement(5, "div");
        builder.AddAttribute(6, "class", "file-meta");
        builder.OpenElement(7, "div");
        builder.AddAttribute(8, "class", "file-meta-main");
        builder.OpenElement(9, "strong");
        builder.AddContent(10, metadata.FileName);
        builder.CloseElement();
        builder.OpenElement(11, "span");
        builder.AddContent(12, $"{FormatBytes(metadata.SizeBytes)} / {metadata.SheetCount} sheets / {(metadata.HasMacro ? "macro" : "no macro")}");
        builder.CloseElement();
        builder.CloseElement();
        builder.OpenComponent<MudIconButton>(13);
        builder.AddAttribute(14, "Icon", Icons.Material.Filled.Close);
        builder.AddAttribute(15, "Size", Size.Small);
        builder.AddAttribute(16, "Color", Color.Default);
        builder.AddAttribute(17, "OnClick", EventCallback.Factory.Create<MouseEventArgs>(this, clearFile));
        builder.AddEventStopPropagationAttribute(18, "onclick", true);
        builder.CloseComponent();
        builder.CloseElement();
    };

    private RenderFragment SummaryCard(string label, int value, string icon, Color color, int tabIndex) =>
        @<MudItem xs="12" sm="6" md="2">
            <MudPaper Class="summary-card clickable-summary" Elevation="0" @onclick="@(() => SelectSummaryTab(tabIndex))" role="button" tabindex="0">
                <MudIcon Icon="@icon" Color="@color" />
                <MudText Typo="Typo.caption">@label</MudText>
                <MudText Typo="Typo.h5">@value.ToString("N0")</MudText>
            </MudPaper>
        </MudItem>;

    private static string FormatBytes(long bytes) => $"{bytes / 1024d / 1024d:N2} MB";

    private static (string Background, string Foreground, string NumberFormat) ParseStyleSignature(string signature)
    {
        var background = string.Empty;
        var foreground = string.Empty;
        var numberFormat = string.Empty;

        foreach (var part in signature.Split('|', StringSplitOptions.RemoveEmptyEntries))
        {
            if (part.StartsWith("bg:", StringComparison.Ordinal))
            {
                background = part[3..];
            }
            else if (part.StartsWith("fg:", StringComparison.Ordinal))
            {
                foreground = part[3..];
            }
            else if (part.StartsWith("num:", StringComparison.Ordinal))
            {
                numberFormat = part[4..];
            }
        }

        return (background, foreground, string.IsNullOrWhiteSpace(numberFormat) ? "標準" : numberFormat);
    }

    private static string? ToCssColor(string openXmlColor)
    {
        if (!openXmlColor.StartsWith("rgb:", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        var hex = openXmlColor[4..];
        if (hex.Length == 8)
        {
            hex = hex[2..];
        }

        return hex.Length == 6 ? $"#{hex}" : null;
    }

    private static string CategoryLabel(DiffCategory category) => category switch
    {
        DiffCategory.Structure => "ファイル構成",
        DiffCategory.Cell => "データ",
        DiffCategory.Formatting => "書式",
        DiffCategory.Macro => "マクロ",
        DiffCategory.Metadata => "名前定義",
        _ => category.ToString()
    };

    private static string MacroModuleName(DiffRecord record)
    {
        if (record.Category != DiffCategory.Macro)
        {
            return string.Empty;
        }

        foreach (var suffix in new[] { " 行差分", " モジュール本体", " 行差分詳細", " モジュール概要" })
        {
            if (record.Item.EndsWith(suffix, StringComparison.Ordinal))
            {
                return record.Item[..^suffix.Length];
            }
        }

        return record.Item is "マクロ比較" or "マクロ有無" or "VBA保護" or "VBA解析"
            ? string.Empty
            : record.Item;
    }

    private static string KindLabel(DiffKind kind) => kind switch
    {
        DiffKind.Added => "追加",
        DiffKind.Removed => "削除",
        DiffKind.Changed => "変更",
        DiffKind.Renamed => "名称変更",
        _ => kind.ToString()
    };

    private static Color KindColor(DiffKind kind) => kind switch
    {
        DiffKind.Added => Color.Success,
        DiffKind.Removed => Color.Error,
        DiffKind.Renamed => Color.Info,
        _ => Color.Warning
    };
}
